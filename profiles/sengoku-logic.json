{
      "logic_name": "Sengoku-Online-Universal-Logic",
        "version": "2.0.0",
          "description": "地理・性別・年齢・血統に基づき、NFTキャラクターのAP効率と人生の分岐を定義するマスターデータ",

            "//1_属性生成プロトコル": "キャラクター生成時のルール定義",
              "generation_protocols": {
                  "gender": {
                        "input_method": "choice",
                              "allow_custom": true,
                                    "options": [
                                            { "id": "male", "label": "男性", "weight": 49 },
                                                    { "id": "female", "label": "女性", "weight": 49 },
                                                            { "id": "non_binary", "label": "ノンバイナリー", "weight": 2 }
                                                                  ]
                                                                      },
                                                                          "spawn_age": {
                                                                                "input_method": "discrete",
                                                                                      "available_formats": {
                                                                                              "type": "discrete",
                                                                                                      "values": [10, 12, 13, 15],
                                                                                                              "default": 13
                                                                                                                    }
                                                                                                                        }
                                                                                                                          },

                                                                                                                            "//2_特性補正値マトリクス": "属性による基礎AP倍率（0.8＝コスト20%減/効率1.25倍）",
                                                                                                                              "trait_modifier_map": {
                                                                                                                                  "gender_traits": {
                                                                                                                                        "male": {
                                                                                                                                                "ap_mult": { "military": 0.9, "construction": 0.9 },
                                                                                                                                                        "visual_key": "m_base"
                                                                                                                                                              },
                                                                                                                                                                    "female": {
                                                                                                                                                                            "ap_mult": { "diplomacy": 0.9, "intelligence": 0.9, "domestic": 0.9 },
                                                                                                                                                                                    "visual_key": "f_base"
                                                                                                                                                                                          },
                                                                                                                                                                                                "non_binary": {
                                                                                                                                                                                                        "ap_mult": { "culture": 0.8, "trade": 0.9 },
                                                                                                                                                                                                                "visual_key": "nb_base"
                                                                                                                                                                                                                      }
                                                                                                                                                                                                                          },
                                                                                                                                                                                                                              "age_traits": {
                                                                                                                                                                                                                                    "ap_max_formula": "100 + (age * 2)",
                                                                                                                                                                                                                                          "learning_rate_formula": "max(0.5, 1.5 - (age * 0.05))"
                                                                                                                                                                                                                                              }
                                                                                                                                                                                                                                                },

                                                                                                                                                                                                                                                  "//3_初期職業決定ロジック": "地理データ(izu.json等)との合成ルール",
                                                                                                                                                                                                                                                    "spawn_probability": {
                                                                                                                                                                                                                                                        "terrain_modifiers": {
                                                                                                                                                                                                                                                              "mountain": { "condition": { "terrain_type": 1 }, "targets": ["samurai", "shinobi"], "mul": 1.5 },
                                                                                                                                                                                                                                                                    "coastal": { "condition": { "elevation_m": { "lt": 10 } }, "targets": ["merchant", "boatman"], "mul": 2.0 },
                                                                                                                                                                                                                                                                          "river_side": { "condition": { "is_river": true }, "targets": ["farmer", "craftsman"], "mul": 1.2 }
                                                                                                                                                                                                                                                                              },
                                                                                                                                                                                                                                                                                  "occupation_pool": [
                                                                                                                                                                                                                                                                                        { "id": "farmer", "base_weight": 60, "label": "農民" },
                                                                                                                                                                                                                                                                                              { "id": "samurai", "base_weight": 15, "label": "武士" },
                                                                                                                                                                                                                                                                                                    { "id": "merchant", "base_weight": 10, "label": "商人" },
                                                                                                                                                                                                                                                                                                          { "id": "monk", "base_weight": 5, "label": "僧侶" },
                                                                                                                                                                                                                                                                                                                { "id": "shinobi", "base_weight": 5, "label": "忍" },
                                                                                                                                                                                                                                                                                                                      { "id": "courtier", "base_weight": 5, "label": "公家" }
                                                                                                                                                                                                                                                                                                                          ]
                                                                                                                                                                                                                                                                                                                            },

                                                                                                                                                                                                                                                                                                                              "//4_職業別APコスト補正": "特定の行動に対する専門化",
                                                                                                                                                                                                                                                                                                                                "occupation_ap_modifiers": {
                                                                                                                                                                                                                                                                                                                                    "samurai": { "military_train": 0.7, "battle_command": 0.8, "tax_collect": 0.9 },
                                                                                                                                                                                                                                                                                                                                        "farmer": { "cultivate": 0.5, "repair": 0.7, "fortify": 0.9 },
                                                                                                                                                                                                                                                                                                                                            "merchant": { "trade_buy": 0.6, "trade_sell": 0.6, "transport": 0.7 },
                                                                                                                                                                                                                                                                                                                                                "shinobi": { "recon": 0.4, "assassinate": 0.6, "propaganda": 0.5 },
                                                                                                                                                                                                                                                                                                                                                    "monk": { "healing": 0.6, "diplomacy_talk": 0.7, "education": 0.7 },
                                                                                                                                                                                                                                                                                                                                                        "courtier": { "imperial_lobby": 0.4, "culture_event": 0.5, "marriage_neg": 0.6 }
                                                                                                                                                                                                                                                                                                                                                          },

                                                                                                                                                                                                                                                                                                                                                            "//5_キャリア遷移(昇格)パス": "人生の進展条件",
                                                                                                                                                                                                                                                                                                                                                              "promotion_paths": [
                                                                                                                                                                                                                                                                                                                                                                  {
                                                                                                                                                                                                                                                                                                                                                                        "id": "bushi_road",
                                                                                                                                                                                                                                                                                                                                                                              "steps": [
                                                                                                                                                                                                                                                                                                                                                                                      { "from": "farmer", "to": "ashigaru", "req": { "military_exp": 100, "gold": 10 } },
                                                                                                                                                                                                                                                                                                                                                                                              { "from": "ashigaru", "to": "samurai", "req": { "military_exp": 500, "land_loyalty": 50 } },
                                                                                                                                                                                                                                                                                                                                                                                                      { "from": "samurai", "to": "daimyo", "req": { "hex_control": 1, "fame": 200 } }
                                                                                                                                                                                                                                                                                                                                                                                                            ]
                                                                                                                                                                                                                                                                                                                                                                                                                },
                                                                                                                                                                                                                                                                                                                                                                                                                    {
                                                                                                                                                                                                                                                                                                                                                                                                                          "id": "tenka_fubu",
                                                                                                                                                                                                                                                                                                                                                                                                                                "steps": [
                                                                                                                                                                                                                                                                                                                                                                                                                                        { "from": "daimyo", "to": "shogun", "req": { "bloodline": "minamoto", "capital_control": true } },
                                                                                                                                                                                                                                                                                                                                                                                                                                                { "from": "daimyo", "to": "kanpaku", "req": { "bloodline": "fujiwara", "court_rank": 1 } }
                                                                                                                                                                                                                                                                                                                                                                                                                                                      ]
                                                                                                                                                                                                                                                                                                                                                                                                                                                          }
                                                                                                                                                                                                                                                                                                                                                                                                                                                            ],

                                                                                                                                                                                                                                                                                                                                                                                                                                                              "//6_世代継承・遺産システム": "死後の引き継ぎ要素",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                "legacy_system": {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                    "inheritance_rules": {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                          "ap_efficiency_carry_over": 0.1,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                "skill_cap_bonus": 0.05
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "bloodline_unlocks": [
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              { "condition": { "max_rank": "daimyo", "province": "伊豆" }, "unlocks": "minamoto_potential" },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    { "condition": { "max_rank": "courtier", "province": "山城" }, "unlocks": "fujiwara_potential" }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        ]
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          },

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            "//7_地域オーバーライド": "特定の令制国固有の補正",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              "province_overrides": {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  "伊豆": {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "samurai_spawn_bonus": 1.2,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              "minamoto_blood_rate": 0.15,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    "special_event": "Hojo_Legacy"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            "山城": {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  "courtier_spawn_bonus": 2.5,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "fujiwara_blood_rate": 0.3,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              "culture_ap_bonus": 0.9
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    
}